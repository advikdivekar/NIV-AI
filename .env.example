# ── LLM Providers ──────────────────────────────────────────────────────────
GROQ_API_KEY=                          # https://console.groq.com/keys
GEMINI_API_KEY=                        # https://aistudio.google.com/app/apikey
OPENROUTER_API_KEY=                    # https://openrouter.ai/keys

# ── LLM Model Overrides (optional — defaults used if blank) ────────────────
GROQ_MODEL_AGENT=llama-3.3-70b-versatile
GROQ_MODEL_FINAL=llama-3.3-70b-versatile
GEMINI_MODEL_AGENT=gemini-2.0-flash
GEMINI_MODEL_FINAL=gemini-2.0-flash
OPENROUTER_MODEL_AGENT=anthropic/claude-3-haiku
OPENROUTER_MODEL_FINAL=anthropic/claude-3-haiku

# ── Firebase / Firestore ───────────────────────────────────────────────────
FIREBASE_PROJECT_ID=                   # GCP project ID
FIREBASE_PRIVATE_KEY=                  # Service account private key (with \n)
FIREBASE_CLIENT_EMAIL=                 # Service account client email

# ── Google APIs ────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=                   # For location/geocoding features
SERPAPI_KEY=                           # https://serpapi.com — rent scraper

# ── WhatsApp (Meta) ────────────────────────────────────────────────────────
WHATSAPP_ENABLED=false                 # Set true to enable WhatsApp bot
WHATSAPP_PHONE_NUMBER_ID=              # From Meta Business → WhatsApp → Phone numbers
WHATSAPP_ACCESS_TOKEN=                 # Permanent access token from Meta App
WHATSAPP_VERIFY_TOKEN=                 # Any random string you choose for webhook verification
WHATSAPP_APP_SECRET=                   # From Meta App Dashboard → App Secret

# ── App Config ─────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:8000     # Comma-separated allowed CORS origins
SECRET_KEY=                            # Random secret for any signed tokens
ENVIRONMENT=development                # development | production
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR
DEMO_API_KEY=                          # Optional: require X-API-Key header on /analyze

# ── Document Uploads ───────────────────────────────────────────────────────
DOCUMENT_UPLOAD_ENABLED=true           # Set false to disable all /documents/* routes
MAX_UPLOAD_SIZE_MB=10                  # Max file size for document uploads

# ── RERA ───────────────────────────────────────────────────────────────────
RERA_LOOKUP_ENABLED=false              # Set true to enable live RERA lookups
